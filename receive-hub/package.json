{
  "name": "pocketflow-final",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:phone": "vite --port=3000 --host=0.0.0.0 --open /?app=systemmap",
    "relay": "node scripts/codex-relay-server.mjs",
    "relay:worker": "node scripts/codex-relay-worker.mjs",
    "build": "vite build",
    "build:lakehouse-public": "VITE_PUBLIC_LAKEHOUSE_ONLY=1 vite build --outDir dist-lakehouse-public",
    "preview": "vite preview",
    "serve:lakehouse-public": "node scripts/lakehouse-public-server.mjs",
    "serve:lakehouse-tunnel": "node scripts/lakehouse-public-tunnel.mjs",
    "aether:integrate": "node scripts/pocketflow-aether-integration.mjs",
    "aether:benchmark": "node scripts/pocketflow-aether-benchmark.mjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.4.3"
  },
  "description": "Phone-first local AI operations shell for vibe-coding teams, with Builder, local LLM, NewsFlow, Archive, Relay and automation control surfaces."
}
